{
  "name": "pi-auto-system-theme",
  "version": "0.1.0",
  "description": "A pi extension that follows system light/dark appearance on macOS, Windows, and Linux.",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "license": "MIT",
  "author": "HoronLee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HoronLee/pi-auto-system-theme.git"
  },
  "bugs": {
    "url": "https://github.com/HoronLee/pi-auto-system-theme/issues"
  },
  "homepage": "https://github.com/HoronLee/pi-auto-system-theme#readme",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "theme",
    "system-theme",
    "macos",
    "windows",
    "linux",
    "catppuccin"
  ],
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "biome check . && tsc --noEmit",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "pack:dry": "pnpm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./extensions/auto-system-theme.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@earendil-works/pi-coding-agent": "^0.79.6",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
